{
    "name": "kiosk-player",
    "version": "1.0.0",
    "description": "Kiosk Fullscreen Player App",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win"
    },
    "build": {
        "appId": "com.kiosksys.player",
        "productName": "KioskPlayer",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "index.html",
            "player.html"
        ],
        "win": {
            "target": "portable"
        }
    },
    "devDependencies": {
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1"
    }
}
